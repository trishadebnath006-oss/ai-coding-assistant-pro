# ─────────────────────────────────────────────────────────────────
#  Environment Variables — copy this file to .env and fill in values
# ─────────────────────────────────────────────────────────────────

# REQUIRED: Your Google Gemini API key.
# Get one free at: https://aistudio.google.com/app/apikey
# Vite reads this at dev/build time and injects it via process.env.GEMINI_API_KEY.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# OPTIONAL: The URL where this app is hosted (used for self-referential links).
APP_URL="http://localhost:5173"
